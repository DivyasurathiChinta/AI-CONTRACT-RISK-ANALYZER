# ============================================================
# AI Contract Risk Analyzer - Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
# If primary model hits quota, these are tried in order (comma-separated)
GEMINI_FALLBACK_MODELS=gemini-2.0-flash
# Seconds between Gemini calls during analysis (reduces 429 errors)
GEMINI_REQUEST_DELAY_SEC=3
# Seconds to wait when quota/rate limit is hit before retry
GEMINI_QUOTA_RETRY_SEC=60

# --- FastAPI Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# --- File Upload Settings ---
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# --- Application Settings ---
APP_NAME=AI Contract Risk Analyzer
APP_VERSION=1.0.0
DEBUG=True

# --- Streamlit Frontend ---
BACKEND_URL=http://localhost:8000
