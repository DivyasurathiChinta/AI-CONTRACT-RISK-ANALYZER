venv/
.venv/
env/
ENV/
.env/

# Uploads (user data — sensitive legal documents)
uploads/
*.pdf

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

